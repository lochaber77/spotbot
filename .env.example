# Copy to .env and fill in. NEVER commit the real .env.

# --- Claude ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024

# --- WAHA (WhatsApp HTTP API) ---
WAHA_BASE_URL=http://localhost:3000
WAHA_SESSION=default
# Optional, only if your WAHA instance requires an API key:
WAHA_API_KEY=

# --- Access control ---
# Comma-separated allow-list of WhatsApp numbers (any format; normalised to digits).
ALLOWED_NUMBERS=447911123456,15551234567

# --- Data / persistence ---
# SQLite lives on the mounted volume.
DB_PATH=/data/app.sqlite

# --- Defaults ---
# IANA timezone used for newly-seen members.
DEFAULT_TIMEZONE=America/New_York
