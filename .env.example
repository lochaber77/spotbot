# Copy to .env and fill in. NEVER commit the real .env.

# --- Claude ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- WAHA (WhatsApp layer) ---
WAHA_URL=http://waha:3000
WAHA_SESSION=default
# Set a secret to protect WAHA's API; leave blank only for first local testing.
WAHA_API_KEY=
# URL WAHA posts inbound messages to. Inside the compose network this is the
# 'app' service; if running WAHA separately, point it at the app's reachable URL.
WEBHOOK_URL=http://app:8000/webhook

# --- Access control ---
# Comma-separated WhatsApp numbers allowed to use the bot (international, no '+').
# Start with ONLY your own number while testing, then add family.
ALLOWED_NUMBERS=447700900000

# --- Misc ---
TZ=Europe/London
