# Copy to .env and fill in. NEVER commit the real .env.

# --- Claude ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- WAHA (WhatsApp layer) ---
WAHA_URL=http://waha:3000
WAHA_SESSION=default
# Set a secret to protect WAHA's API; leave blank only for first local testing.
WAHA_API_KEY=
# URL WAHA posts inbound messages to. Inside the compose network this is the
# 'app' service; if running WAHA separately, point it at the app's reachable URL.
WEBHOOK_URL=http://app:8000/webhook

# --- Access control ---
# Comma-separated WhatsApp numbers allowed to use the bot (international, no '+').
# Start with ONLY your own number while testing, then add family.
ALLOWED_NUMBERS=447700900000

# --- Google Calendar (M3, optional) ---
# The shared calendar's id (e.g. abc123@group.calendar.google.com), shared with
# the service account with "Make changes to events". Leave GOOGLE_CALENDAR_ID
# blank to keep calendar features disabled — the bot will say so if asked.
GOOGLE_CALENDAR_ID=
# Path INSIDE the container to the service-account key (mounted read-only).
GOOGLE_SERVICE_ACCOUNT_JSON=/secrets/service-account.json
# Host path to that key, mounted into the app container (see docker-compose).
GOOGLE_SERVICE_ACCOUNT_HOST_PATH=./secrets/service-account.json
# How long a confirm-first prompt (e.g. "add this to the calendar?") stays valid.
CONFIRMATION_TTL_MINUTES=30

# --- Gmail drafts (M4, per-user, opt-in) ---
# Path INSIDE the container to per-member OAuth tokens (<number>.json), produced
# by scripts/gmail_authorize.py and mounted read-only. Email is DRAFT-ONLY and
# enabled only for members who have a token file here.
GMAIL_TOKENS_DIR=/secrets/gmail
# Host directory holding those token files, mounted into the app container.
GMAIL_TOKENS_HOST_PATH=./secrets/gmail

# --- Misc ---
TZ=Europe/London
